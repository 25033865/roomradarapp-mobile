{
  "expo": {
    "name": "roomradarapp-mobile",
    "slug": "roomradarapp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/RoomRadar.png",
    "scheme": "roomradarappmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/RoomRadarHomeIcon.png",
      "supportsTablet": true,
      "infoPlist": {
        "CADisableMinimumFrameDurationOnPhone": true,
        "UIPreferredDisplayModeName": "HighFrameRate"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/RoomRadarHomeIcon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "enablePreferredFrameRate": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/RoomRadar.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/RoomRadarHomeIcon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
